# Poiesis 环境变量示例文件
# 复制为 .env 后填入真实值，再执行 docker compose up -d --build
#
# 注意：请勿将含有真实密钥的 .env 文件提交到版本库！

# ── 安全密钥（必填，用于 API Key 加密与 JWT 签名）────────────────
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
POIESIS_SECRET_KEY=

# ── 管理员账号（首次启动自动创建，不存在时生效）────────────────────
POIESIS_ADMIN_USER=admin
POIESIS_ADMIN_PASS=CHANGE_ME_IN_PRODUCTION

# ── LLM API 密钥（可在 Web 界面设置，也可在此配置）───────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Embedding 模式 ──────────────────────────────────────────────
# dummy：使用 SHA-256 哈希向量（离线、零依赖，适合首次启动或 CI）
# real ：使用 sentence-transformers（首次运行会下载 ~90MB 模型）
POIESIS_EMBEDDING_MODE=dummy

# ── 镜像版本（拉取预构建镜像时使用）──────────────────────────
# latest：跟随最新构建；也可锁定为具体版本，例如 v0.1.0
POIESIS_IMAGE_TAG=latest

# ── 前端 API 地址（使用 Nginx 反代时无需设置）──────────────────
# 若前端独立部署（非 Nginx 反代模式），取消注释并填入后端地址：
# VITE_API_BASE_URL=http://localhost:8000
