# 后端 API 容器
# 基于 python:3.11-slim，安装 Poiesis 并通过 uvicorn 暴露 FastAPI 服务

FROM python:3.11-slim

# 设置工作目录
WORKDIR /app

# 安装系统依赖（faiss-cpu 等需要 libgomp）
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# 先复制依赖声明文件，利用 Docker 层缓存
COPY pyproject.toml ./
COPY poiesis/__init__.py poiesis/__init__.py

# 安装项目（包含所有运行时依赖）
COPY . .
RUN pip install --no-cache-dir .

# 暴露 API 端口
EXPOSE 8000

# 支持的环境变量：
#   OPENAI_API_KEY        - OpenAI API 密钥
#   ANTHROPIC_API_KEY     - Anthropic API 密钥
#   POIESIS_EMBEDDING_MODE - embedding 模式：real / dummy（默认 dummy，避免首次拉起下载模型失败）
#   POIESIS_CONFIG        - 配置文件路径（默认 /app/config.yaml）
ENV POIESIS_EMBEDDING_MODE=dummy

# 启动命令：通过 CLI serve 子命令启动，读取挂载的 config.yaml
CMD ["poiesis", "serve", "--config", "/app/config.yaml", "--host", "0.0.0.0", "--port", "8000"]
