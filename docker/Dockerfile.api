# syntax=docker/dockerfile:1
# 后端 API 容器
# 基于 python:3.11-slim，安装 Poiesis 并通过 uvicorn 暴露 FastAPI 服务

FROM python:3.11-slim

# 设置工作目录
WORKDIR /app

# 安装系统依赖（faiss-cpu 等需要 libgomp）
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# ── 依赖层（缓存友好）────────────────────────────────────────────
# 1. 仅复制依赖声明文件，此层在依赖未变时始终命中缓存
COPY pyproject.toml ./
# 2. 创建占位包结构，使 pip 能解析 pyproject.toml 而无需完整源码
RUN mkdir -p poiesis && touch poiesis/__init__.py
# 3. 安装所有运行时依赖（利用 BuildKit pip 缓存，跨构建复用下载内容）
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -U pip && pip install .

# ── 源码层（仅在业务代码变更时失效）──────────────────────────────
# 4. 复制完整源码（此层变更不会触发依赖重新下载）
COPY . .
# 5. 用真实源码重新安装项目本体（跳过依赖，复用上层已缓存的包）
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-deps .

# 暴露 API 端口
EXPOSE 8000

# 支持的环境变量：
#   OPENAI_API_KEY         - OpenAI API 密钥
#   ANTHROPIC_API_KEY      - Anthropic API 密钥
#   POIESIS_EMBEDDING_MODE - embedding 模式：real / dummy（默认 dummy，避免首次拉起下载模型失败）
#   POIESIS_CONFIG         - 配置文件路径（默认 /app/config.yaml）
ENV POIESIS_EMBEDDING_MODE=dummy

# 启动命令：通过 CLI serve 子命令启动，读取挂载的 config.yaml
CMD ["poiesis", "serve", "--config", "/app/config.yaml", "--host", "0.0.0.0", "--port", "8000"]
